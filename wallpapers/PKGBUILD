pkgname=c-os-wallpapers
pkgver=1.0
pkgrel=1
pkgdesc="C-OS Custom Wallpapers"
arch=('any')
url="https://github.com/canacikbas2010-blip/c-os-repo"
license=('GPL')
source=()

package() {
    mkdir -p "$pkgdir/usr/share/backgrounds"
    cp -r "$srcdir"/../* "$pkgdir/usr/share/backgrounds/" 2>/dev/null || true
}
